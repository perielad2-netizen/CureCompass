APP_NAME=CureCompass API
# Use production (or staging) on servers so Celery tasks are not run eagerly in the API process.
ENVIRONMENT=development
API_V1_PREFIX=/api
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
ALGORITHM=HS256

DATABASE_URL=postgresql+psycopg://postgres:123456@localhost:5432/curecompass
REDIS_URL=redis://localhost:6379/0

OPENAI_API_KEY=
OPENAI_RESPONSES_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# When ingestion adds new items, run AI enrichment in the background (plain-language summaries + Ask AI vectors).
AUTO_ENRICH_AFTER_INGEST=true
# Cap items enriched per run (newest first). Set 0 for no limit (can be expensive).
AUTO_ENRICH_MAX_ITEMS=50

NCBI_API_KEY=
NCBI_TOOL_NAME=CureCompass
NCBI_CONTACT_EMAIL=you@example.com
CLINICAL_TRIALS_BASE_URL=https://clinicaltrials.gov/api/v2
PUBMED_EUTILS_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
OPENFDA_BASE_URL=https://api.fda.gov

FRONTEND_URL=http://localhost:3000
PASSWORD_RESET_TOKEN_HOURS=2

# User PDF uploads (sensitive). Restrict filesystem permissions on the server; not committed to git by default.
PRIVATE_DOCUMENTS_DIR=./data/private_documents
PRIVATE_DOCUMENT_MAX_BYTES=5242880
PRIVATE_DOCUMENT_MAX_EXTRACTED_CHARS=200000

# Skip re-running external ingestion for non-admin users if this condition succeeded within N hours.
INGESTION_COOLDOWN_HOURS=4

# When true, Ask AI (research modes) may call Orphadata + MedlinePlus for extra reference snippets
# if indexed research already exists. Respects NLM rate limits; set false to avoid outbound calls.
MEDICAL_INTEL_LIVE_IN_ASK_AI=true
# Merge indexed + live Orphadata/MedlinePlus into one deduped/ranked AGGREGATED_RANKED_EVIDENCE block for Ask AI.
# On failure, falls back to classic TRUSTED_INDEXED_EVIDENCE (+ optional LIVE_REFERENCE_HINTS if MEDICAL_INTEL_LIVE_IN_ASK_AI).
MEDICAL_INTEL_AGGREGATED_EVIDENCE_IN_ASK_AI=true
# Phase 4: add simple_explanation, key_facts, treatment/trial/safety sections, etc. (keeps all legacy fields).
# Strongly recommended with MEDICAL_INTEL_AGGREGATED_EVIDENCE_IN_ASK_AI=true so answers ground on ranked merged evidence.
MEDICAL_INTEL_STRUCTURED_ANSWER=true

# Leave SMTP_HOST empty to skip sending (digest/reset log warnings only).
# MailHog/Mailpit: SMTP_HOST=localhost SMTP_PORT=1025 SMTP_USE_TLS=false
# Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_USE_TLS=true — use an App Password if 2FA is on.
SMTP_HOST=
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@curecompass.app
# Optional hard gate for admin reports page (must match an admin user's email).
ADMIN_OWNER_EMAIL=
# Optional Reply-To for password-reset email only.
SMTP_REPLY_TO=
# Research briefings only. If set, most mail apps send "Reply" here instead of to SMTP_FROM.
# Email cannot be truly "one-way": power users can still use "Reply to sender". Point this at a
# blackhole or unmonitored address (e.g. noreply@YOURDOMAIN with no mailbox, or a second Gmail you never read).
# If both are empty, replies go to SMTP_FROM (e.g. your noreply@gmail.com inbox).
SMTP_DIGEST_REPLY_TO=
